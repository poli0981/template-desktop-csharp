<?xml version="1.0" encoding="utf-8"?>
<configuration>

  <!--
    Repo-scoped NuGet config. Pins the feed list so Dependabot, CI, and local
    dev all see the same packages. Add private feeds here when you need them
    (and pair with `<packageSourceCredentials>` in a *separate* untracked
    config — never commit credentials).
  -->

  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>

  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>

  <packageRestore>
    <add key="enabled" value="True" />
    <add key="automatic" value="True" />
  </packageRestore>

  <bindingRedirects>
    <add key="skip" value="False" />
  </bindingRedirects>

  <packageManagement>
    <add key="format" value="1" />
    <add key="disabled" value="False" />
  </packageManagement>

</configuration>
